# ---------------------------------------------------------------------------
# Sepolia deploy config — copy this file to `.env` and fill in real values.
# `.env` is gitignored; NEVER commit real keys.
# Used by `npm run deploy:sepolia`.
# ---------------------------------------------------------------------------

# HTTPS RPC endpoint for the Sepolia testnet.
# Get one free from Alchemy (https://alchemy.com) or Infura (https://infura.io):
# create an app on the "Sepolia" network and copy its HTTPS URL.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Private key of a THROWAWAY wallet funded with Sepolia test ETH from a faucet.
# Use a brand-new wallet only — never one that holds real funds.
# May be given with or without the leading 0x.
SEPOLIA_PRIVATE_KEY=your_throwaway_wallet_private_key
