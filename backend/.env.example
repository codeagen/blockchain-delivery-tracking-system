# ---------------------------------------------------------------------------
# Backend environment configuration (copy to .env and fill in real values)
# ---------------------------------------------------------------------------

# HTTP port the NestJS API listens on
PORT=3001

# ---------------------------------------------------------------------------
# Postgres (off-chain cache for users/auth — NOT authoritative delivery state)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=blockchain_delivery

# Secret used to sign/verify JWT access tokens (use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret

# How long issued JWTs remain valid
JWT_EXPIRES_IN=1d

# JSON-RPC endpoint of the Ethereum node (Ganache / Hardhat local node)
RPC_URL=http://127.0.0.1:8545

# Deployed DeliveryManagement contract address.
# Leave blank until the blockchain tier deploys the contract — the backend
# still boots; chain calls return a clear "not configured" error.
CONTRACT_ADDRESS=

# Private key of the contract admin / deployer account. The backend uses it to
# (a) call admin-only actions (assignAgent) and (b) fund each user's custodial
# wallet so they can pay gas. Per-user actions are signed by each user's own
# generated wallet. This account must be funded (e.g. a Ganache/Hardhat account).
SIGNER_PRIVATE_KEY=
